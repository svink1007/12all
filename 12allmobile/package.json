{
  "name": "12allmobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "react-scripts start",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "serve": "ionic serve",
    "serve:debug": "env-cmd -f .env.debug npm start",
    "serve:development": "env-cmd -f .env.development npm start",
    "serve:production": "env-cmd -f .env.production npm start",
    "build:debug": "env-cmd -f .env.debug react-scripts build",
    "build:development": "env-cmd -f .env.development react-scripts build",
    "build:production": "env-cmd -f .env.production react-scripts build",
    "android-run": "ionic cap run android",
    "android-run-livereload": "ionic cap run android --livereload",
    "android-run-livereload-external": "ionic cap run android -l --external",
    "android-serve-https": "ionic cap run android -l --external --https",
    "android-serve-device": "ionic cap run android -l --external --device",
    "android-serve": "ionic cap run android -l --external",
    "android-add": "ionic cap add android",
    "android-build:development": "npm run build:development && ionic cap build android --no-open --no-build",
    "android-build:production": "npm run build:production && ionic cap build android --no-open --no-build",
    "android-open": "ionic cap open android",
    "android-sync": "ionic cap sync android",
    "android-sync:debug": "npm run build:debug && ionic cap sync android --no-build",
    "android-sync:development": "npm run build:development && ionic cap sync android --no-build",
    "android-sync:production": "npm run build:production && ionic cap sync android --no-build",
    "android-copy:debug": "npm run build:debug && ionic cap copy android --no-build",
    "android-copy:development": "npm run build:development && ionic cap copy android --no-build",
    "android-copy:production": "npm run build:production && ionic cap copy android --no-build",
    "android-assemle-release": "cd android && gradlew assembleRelease",
    "android-bundle-release": "cd android && gradlew bundleRelease",
    "linux-android-copy:production": "npm run build:production && sudo ionic cap copy android --no-build",
    "linux-android-assemle-release": "cd android && sudo ./gradlew assembleRelease",
    "cap-run-help": "ionic cap run --help",
    "ios-add": "ionic cap add ios",
    "ios-build": "ionic cap build ios",
    "ios-open": "ionic cap open ios",
    "ios-run": "ionic cap run ios",
    "ios-run-livereload": "ionic cap run ios --livereload",
    "ios-run-livereload-external": "ionic cap run ios --livereload --external",
    "ios-copy:debug": "npm run build:debug && ionic cap copy ios --no-build",
    "ios-copy:development": "npm run build:development && ionic cap copy ios --no-build",
    "ios-copy:production": "npm run build:production && ionic cap copy ios --no-build",
    "ios-live": "ionic cap run ios -l --external",
    "ios-sync:debug": "npm run build:debug && ionic cap sync ios --no-build",
    "ios-sync:development": "npm run build:development && ionic cap sync ios --no-build",
    "ios-sync:production": "npm run build:production && ionic cap sync ios --no-build",
    "jetifier": "npx jetifier"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
